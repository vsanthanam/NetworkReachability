{"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","level":2,"type":"heading","text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The easiest way use "},{"type":"reference","isActive":true,"identifier":"doc:\/\/NetworkReachability\/documentation\/NetworkReachability\/ReachabilityMonitor"},{"type":"text","text":" is to use its static "},{"type":"codeVoice","code":"reachability"},{"type":"text","text":" property"}]},{"type":"codeListing","syntax":"swift","code":["import NetworkReachability","","do {","    let reachability = try ReachabilityMonitor.reachability","    \/\/ Do something with `reachability`","} catch {","    \/\/ Handle errors","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Unlike "},{"type":"reference","isActive":true,"identifier":"doc:\/\/NetworkReachability\/documentation\/NetworkReachability\/NetworkMonitor"},{"type":"text","text":", "},{"type":"reference","isActive":true,"identifier":"doc:\/\/NetworkReachability\/documentation\/NetworkReachability\/ReachabilityMonitor"},{"type":"text","text":"’s synchronous API is gauranteed to provide up-date-values."}]},{"anchor":"Observing-reachability-updates","level":3,"type":"heading","text":"Observing reachability updates"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you need to observe all reachability changes, "},{"type":"reference","isActive":true,"identifier":"doc:\/\/NetworkReachability\/documentation\/NetworkReachability\/ReachabilityMonitor"},{"type":"text","text":" provides several asynchronous APIs that will allow you to integrate reachability data into any existing pipeline."}]},{"anchor":"Closures","level":5,"type":"heading","text":"Closures"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use a closure to observe reachability over time. You can pass in the closure on initialization, or add one later using the "},{"type":"codeVoice","code":"updateHandler"},{"type":"text","text":" property. The closure returns result types, which means they could contain errors instead of values."}]},{"type":"codeListing","syntax":"swift","code":["import NetworkReachability","","final class MyClass {","","    var monitor: ReachabilityMonitor?","","    func startMonitoring() {","        stopMonitoring()","        monitor = ReachabilityMonitor(updateHandler: { (monitor: ReachabilityMonitor, result: ReachabilityMonitor.Result) in","            do {","                let reachability = try result.get()","                \/\/ Do something with `monitor` or `reachability`","            } catch {","                \/\/ Handle error","            }","        }","    }","","    func stopMonitoring() {","        monitor = nil","    }","","}"]},{"type":"aside","style":"important","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"By default, instances of "},{"type":"reference","isActive":true,"identifier":"doc:\/\/NetworkReachability\/documentation\/NetworkReachability\/ReachabilityMonitor"},{"type":"text","text":" always call their update handlers on the main thread. You can change this behavior by setting the monitor’s "},{"type":"codeVoice","code":".updateQueue"},{"type":"text","text":" property."}]}]},{"anchor":"Swift-Concurrency","level":5,"type":"heading","text":"Swift Concurrency"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use an "},{"type":"codeVoice","code":"AsyncSequence"},{"type":"text","text":" to observe reachability updates over time using Swift Concurrency"}]},{"type":"codeListing","syntax":"swift","code":["import NetworkReachability","","final class MyClass {","    ","    var monitorTask: Task?","","    func startObserving() {","        stopObserving()","        monitorTask = Task {","            do {","                for try await reachability in ReachabilityMonitor.reachabilityMonitorUpdates {","                    \/\/ Do something with `reachability`","                }","            } catch {","                \/\/ Handle error","            }","        }","    }","","    func startObserving() {","        monitorTask?.cancel()","        monitorTask = nil","    }","}"]},{"type":"aside","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"This API requires iOS 13, macOS 10.15, tvOS 13, or watchOS 6"}]}]},{"anchor":"Delegation","level":5,"type":"heading","text":"Delegation"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use "},{"type":"reference","isActive":true,"identifier":"doc:\/\/NetworkReachability\/documentation\/NetworkReachability\/ReachabilityMonitorDelegate"},{"type":"text","text":" to recieve callbacks when the reachability changes. You can pass in a delegate object when the monitor is initialized, or you can assign one later."}]},{"type":"codeListing","syntax":"swift","code":["import NetworkReachability","","final class MyClass: ReachabilityMonitorDelegate {","","    var monitor: ReachabilityMonitor?","","    func startMonitoring() {","        stopMonitoring()","        monitor = ReachabilityMonitor(delegate: self)","    }","","    func stopMonitoring() {","        monitor = nil","    }","","    \/\/ MARK: - ReachabilityMonitorDelegate","","    func reachabilityMonitor(_ monitor: ReachabilityMonitor, didUpdateReachability reachability: Reachability)","        \/\/ Do something with `reachability`","    }","","    func reachabilityMonitor(_ monitor: ReachabilityMonitor, didFailWithError error: Error) {","        \/\/ Handle error","    }","","}"]},{"type":"aside","style":"important","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"By default, instances of "},{"type":"reference","isActive":true,"identifier":"doc:\/\/NetworkReachability\/documentation\/NetworkReachability\/ReachabilityMonitor"},{"type":"text","text":" always execute their delegate callbacks on the main thread. You can change this behavior by setting the monitor’s "},{"type":"codeVoice","code":".updateQueue"},{"type":"text","text":" property."}]}]},{"anchor":"NotificationCenter","level":5,"type":"heading","text":"NotificationCenter"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you have retained an instance of "},{"type":"reference","isActive":true,"identifier":"doc:\/\/NetworkReachability\/documentation\/NetworkReachability\/ReachabilityMonitor"},{"type":"text","text":" in memory, but do not have access to it in the part of your code that needs reachability updates, you can"},{"type":"text","text":" "},{"type":"text","text":"observe reachability changes by observing notifications with the name "},{"type":"codeVoice","code":"Notification.Name.reachabilityChanged"},{"type":"text","text":" on the default notification center. The notification’s "},{"type":"codeVoice","code":".object"},{"type":"text","text":" property will contain the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/NetworkReachability\/documentation\/NetworkReachability\/ReachabilityMonitor"},{"type":"text","text":". From there, you can use "},{"type":"codeVoice","code":"currentReachability"},{"type":"text","text":" property of the monitor, which you now know will be up-to-date thanks to the notification."}]},{"type":"codeListing","syntax":"swift","code":["import Foundation","import NetworkReachability","","final class MyClass {","","    var monitor: ReachabilityMonitor?","","    func startMonitoring() {","        stopMonitoring()","        NotificationCenter.default.addObserver(self, selector: #selector(handleUpdate:), name: .reachabilityhChanged)","        monitor = ReachabilityMonitor()","    }","","    func stopMonitoring() {","        monitor = nil","        NotificationCenter.default.removeObserver(self, name: .reachabilityChanged)","    }","","    @objc","    func handleUpdate(_ notification: Notification) {","        guard let monitor = notification.object as? ReachabilityMonitor else {","            return","        }","        do {","            let reachability = try monitor.currentReachability","        } catch {","            \/\/ Do something with `reachability`","        }","    }","","    deinit {","        NotificationCenter.default.removeObserver(self, name: .reachabilityChanged)","    }","","}"]},{"type":"aside","style":"important","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"By default, instances of "},{"type":"reference","isActive":true,"identifier":"doc:\/\/NetworkReachability\/documentation\/NetworkReachability\/ReachabilityMonitor"},{"type":"text","text":" always post their notifications on the main thread. You can change this behavior by setting the monitor’s "},{"type":"codeVoice","code":".updateQueue"},{"type":"text","text":" property."}]}]},{"anchor":"Combine","level":5,"type":"heading","text":"Combine"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can observe reachability changes using a "},{"type":"reference","isActive":true,"identifier":"https:\/\/developer.apple.com\/documentation\/combine"},{"type":"text","text":" with the "},{"type":"codeVoice","code":"reachabilityPublisher"},{"type":"text","text":" static property."}]},{"type":"codeListing","syntax":"swift","code":["import Combine","import NetworkReachability","","final class MyClass {","    ","    var monitorCancellable: AnyCancellable?","","    func startObserving() {","        stopObserving()","        monitorCancellable = ReachabilityMonitor.reachabilityPublisher","            .map(\\.status.isReachable)","            .replaceError(with: false)","            .sink { isReachable in","                \/\/ Do something with `isReachable`","            }","    }","","    func startObserving() {","        monitorCancellable?.cancel()","        monitorCancellable = nil","    }","","    deinit {","        monitorCancellable?.cancel()","    }","}"]},{"type":"aside","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"This API requires iOS 13, macOS 10.15, tvOS 13, or watchOS 6"}]}]}]}],"schemaVers