{"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","level":2,"type":"heading","text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The easiest way to use a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/NetworkReachability\/documentation\/NetworkReachability\/NetworkMonitor"},{"type":"text","text":" is to initialize an instance and retain it memory."},{"type":"text","text":" "},{"type":"text","text":"From there you can access the "},{"type":"codeVoice","code":"currentPath"},{"type":"text","text":" property whenever you need to know the last known network path."}]},{"type":"codeListing","syntax":"swift","code":["import Network","import NetworkReachability","","let monitor = NetworkMonitor()","let path = monitor.currentPath"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This synchronous API is easy to use, but "},{"type":"codeVoice","code":"currentPath"},{"type":"text","text":" isn’t always up-to-date and is best used when a monitor instance has been retained in memory for some time. As such, it will be insufficient for many use cases and is not recommended."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Instead, "},{"type":"reference","isActive":true,"identifier":"doc:\/\/NetworkReachability\/documentation\/NetworkReachability\/NetworkMonitor"},{"type":"text","text":" offers a variety of asynchronous APIs for both single value retrieval as well as constant value observation that are gauranteed to offer up-to-date values."}]},{"anchor":"Retrieving-the-current-network-path","level":3,"type":"heading","text":"Retrieving the current network path"},{"type":"paragraph","inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/NetworkReachability\/documentation\/NetworkReachability\/NetworkMonitor"},{"type":"text","text":" allows you to retrieve the last known network path using two asyncronous APIs. Unlike the synchronous API described above which provides values that may or may not be up to date, the asynchronous APIs gaurantee you access to an up-to-date value."}]},{"anchor":"Closures","level":5,"type":"heading","text":"Closures"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To asynchronously retrieve the last known network path, you can use the "},{"type":"codeVoice","code":"networkPath(completionHandler:)"},{"type":"text","text":" static method. The provided closure will be executed exactly once."}]},{"type":"codeListing","syntax":"swift","code":["import Network","import NetworkReachability","","func updateReachability() {","    NetworkMonitor.networkPath(completionHandler: { (path: NWPath) in ","        \/\/ Do something with `path`","    }","}"]},{"style":"important","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""},{"type":"codeVoice","code":"completionHandler"},{"type":"text","text":" is always called in the main thread."}]}],"type":"aside","name":"Important"},{"anchor":"Swift-Concurrency","level":5,"type":"heading","text":"Swift Concurrency"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can also retrieve the last known network path using Swift Concurrency via the "},{"type":"codeVoice","code":"networkPath"},{"type":"text","text":" static property."}]},{"type":"codeListing","syntax":"swift","code":["import Network","import NetworkReachability","","func updateReachability() {","    Task {","        let path = await NetworkMonitor.networkPath","        \/\/ Do something with `path`","    }","}"]},{"style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"This API requires iOS 13, macOS 10.15, tvOS 13, or watchOS 6"}]}],"type":"aside","name":"Note"},{"anchor":"Observing-network-path-updates","level":3,"type":"heading","text":"Observing network path updates"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you need to observe all network path changes, "},{"type":"reference","isActive":true,"identifier":"doc:\/\/NetworkReachability\/documentation\/NetworkReachability\/NetworkMonitor"},{"type":"text","text":" provides several asynchronous APIs that will allow you to integrate network path data into any existing pipeline"}]},{"anchor":"Closures","level":5,"type":"heading","text":"Closures"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use a closure to observe network path updates over time. You can pass in the closure on initialization, or add one later using the "},{"type":"codeVoice","code":"updateHandler"},{"type":"text","text":" property."}]},{"type":"codeListing","syntax":"swift","code":["import Network","import NetworkReachability","","final class MyClass {","","    var monitor: NetworkMonitor?","","    func startMonitoring() {","        stopMonitoring()","        monitor = NetworkMonitor(updateHandler: { (monitor: NetworkMonitor, path: NWPath) in","            \/\/ Do something with `monitor` or `path`","        }","    }","","    func stopMonitoring() {","        monitor = nil","    }","","}"]},{"style":"important","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"By default, instances of "},{"type":"reference","isActive":true,"identifier":"doc:\/\/NetworkReachability\/documentation\/NetworkReachability\/NetworkMonitor"},{"type":"text","text":" always call their update handlers on the main thread. You can change this behavior by setting the monitor’s "},{"type":"codeVoice","code":".updateQueue"},{"type":"text","text":" property."}]}],"type":"aside","name":"Important"},{"anchor":"Swift-Concurrency","level":5,"type":"heading","text":"Swift Concurrency"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use an "},{"type":"codeVoice","code":"AsyncSequence"},{"type":"text","text":" to observe network path updates over time using Swift Concurrency"}]},{"type":"codeListing","syntax":"swift","code":["import Network","import NetworkReachability","","final class MyClass {","    ","    var monitorTask: Task?","","    func startObserving() {","        stopObserving()","        monitorTask = Task {","            for await path in NetworkMonitor.networkMonitorUpdates {","                \/\/ Do something with `path`","            }","        }","    }","","    func startObserving() {","        monitorTask?.cancel()","        monitorTask = nil","    }","}"]},{"style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"This API requires iOS 13, macOS 10.15, tvOS 13, or watchOS 6"}]}],"type":"aside","name":"Note"},{"anchor":"Delegation","level":5,"type":"heading","text":"Delegation"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use "},{"type":"reference","isActive":true,"identifier":"doc:\/\/NetworkReachability\/documentation\/NetworkReachability\/NetworkMonitorDelegate"},{"type":"text","text":" to recieve callbacks when the network path changes. You can pass in a delegate object when the monitor is initialized, or you can assign one later."}]},{"type":"codeListing","syntax":"swift","code":["import Network","import NetworkReachability","","final class MyClass: NetworkMonitorDelegate {","","    var monitor: NetworkMonitor?","","    func startMonitoring() {","        stopMonitoring()","        monitor = NetworkMonitor(delegate: self)","    }","","    func stopMonitoring() {","        monitor = nil","    }","","    \/\/ MARK: - NetworkMonitorDelegate","","    func networkMonitor(_ monitor: NetworkMonitor, didUpdateNetworkPath networkPath: NWPath) {","        \/\/ Do something with `networkPath`","    }","","}"]},{"style":"important","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"By default, instances of "},{"type":"reference","isActive":true,"identifier":"doc:\/\/NetworkReachability\/documentation\/NetworkReachability\/NetworkMonitor"},{"type":"text","text":" always call execute their delegate callbacks on the main thread. You can change this behavior by setting the monitor’s "},{"type":"codeVoice","code":".updateQueue"},{"type":"text","text":" property."}]}],"type":"aside","name":"Important"},{"anchor":"NotificationCenter","level":5,"type":"heading","text":"NotificationCenter"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you have retained an instance of "},{"type":"reference","isActive":true,"identifier":"doc:\/\/NetworkReachability\/documentation\/NetworkReachability\/NetworkMonitor"},{"type":"text","text":" in memory, but do not have access to it in the part of your code that needs network path updates, you can"},{"type":"text","text":" "},{"type":"text","text":"observe network path changes by observing notifications with the name "},{"type":"codeVoice","code":"Notification.Name.networkPathChanged"},{"type":"text","text":" on the default notification center. The notification’s "},{"type":"codeVoice","code":".object"},{"type":"text","text":" property will contain the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/NetworkReachability\/documentation\/NetworkReachability\/NetworkMonitor"},{"type":"text","text":". From there, you can use "},{"type":"codeVoice","code":"currentPath"},{"type":"text","text":" property of the monitor, which you now know will be up-to-date thanks to the notification."}]},{"type":"codeListing","syntax":"swift","code":["import Foundation","import Network","import NetworkReachability","","final class MyClass {","","    var monitor: NetworkMonitor?","","    func startMonitoring() {","        stopMonitoring()","        NotificationCenter.default.addObserver(self, selector: #selector(handleUpdate:), name: .networkPathChanged)","        monitor = NetworkMonitor()","    }","","    func stopMonitoring() {","        monitor = nil","        NotificationCenter.default.removeObserver(self, name: .networkPathChanged)","    }","","    @objc","    func handleUpdate(_ notification: Notification) {","        guard let monitor = notification.object as? NetworkMonitor else {","            return","        }","        let path = monitor.currentPath","        \/\/ Do something with `path`","    }","","    deinit {","        NotificationCenter.default.removeObserver(self, name: .networkPathChanged)","    }","","}"]},{"style":"important","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"By default, instances of "},{"type":"reference","isActive":true,"identifier":"doc:\/\/NetworkReachability\/documentation\/NetworkReachability\/NetworkMonitor"},{"type":"text","text":" always post their notifications on the main thread. You can change this behavior by setting the monitor’s "},{"type":"codeVoice","code":".updateQueue"},{"type":"text","text":" property."}]}],"type":"aside","name":"Important"},{"anchor":"Combine","level":5,"type":"heading","text":"Combine"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can observe network path changes using a "},{"type":"reference","isActive":true,"identifier":"https:\/\/developer.apple.com\/documentation\/combine"},{"type":"text","text":" with the "},{"type":"codeVoice","code":"networkPathPublisher"},{"type":"text","text":" static property."}]},{"type":"codeListing","syntax":"swift","code":["import Combine","import Network","import NetworkReachability","","final class MyClass {","    ","    var monitorCancellable: AnyCancellable?","","    func startObserving() {","        stopObserving()","        monitorCancellable = NetworkMonitor.networkPathPublisher","            .map(\\.status)","            .sink { status in","                \/\/ Do something with `status`","            }","    }","","    func startObserving() {","        monitorCancellable?.cancel()","        monitorCancellable = nil","    }","","    deinit {","        monitorCancellable?.cancel()","    }","}"]},{"style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"This API requires iOS 13, macOS 10.15, tvOS 13, or watchOS 6"}]}],"type":"aside","name":"Note"}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"variants":[{"paths":["\/documentation\/networkreachability\/networkmonitorguide"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc:\/\/NetworkReachability\/documentation\/NetworkReachability\/NetworkMonitorGuide","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"Learn how to use Network Monitor APIs"}],"kind":"article","metadata":{"roleHeading":"Article","title":"Network Monitor Programming Guide","role":"article","modules":[{"name":"NetworkReachability"}]},"hierarchy":{"paths":[["doc:\/\/NetworkReachability\/documentation\/NetworkReachability"]]},"seeAlsoSections":[{"title":"Network Monitor","identifiers":["doc:\/\/NetworkReachability\/documentation\/NetworkReachability\/NetworkMonitor","doc:\/\/NetworkReachability\/documentation\/NetworkReachability\/NetworkMonitorDelegate"],"generated":true}],"references":{"doc://NetworkReachability/documentation/NetworkReachability":{"role":"collection","title":"NetworkReachability","abstract":[{"type":"text","text":"A Swift replacement for "},{"type":"codeVoice","code":"SCNetworkReachability"},{"type":"text","text":" & "},{"type":"codeVoice","code":"NWPathMonitor"},{"type":"text","text":" with support for structured concurrency."}],"identifier":"doc:\/\/NetworkReachability\/documentation\/NetworkReachability","kind":"symbol","type":"topic","url":"\/documentation\/networkreachability"},"doc://NetworkReachability/documentation/NetworkReachability/NetworkMonitor":{"role":"symbol","title":"NetworkMonitor","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"NetworkMonitor"}],"abstract":[{"type":"text","text":"A class used to observe network path changes"}],"identifier":"doc:\/\/NetworkReachability\/documentation\/NetworkReachability\/NetworkMonitor","kind":"symbol","type":"topic","navigatorTitle":[{"kind":"identifier","text":"NetworkMonitor"}],"url":"\/documentation\/networkreachability\/networkmonitor"},"https://developer.apple.com/documentation/combine":{"title":"Combine","titleInlineContent":[{"type":"text","text":"Combine"}],"type":"link","identifier":"https:\/\/developer.apple.com\/documentation\/combine","url":"https:\/\/developer.apple.com\/documentation\/combine"},"doc://NetworkReachability/documentation/NetworkReachability/NetworkMonitorDelegate":{"role":"symbol","title":"NetworkMonitorDelegate","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"NetworkMonitorDelegate"}],"abstract":[{"type":"text","text":"A protocol used to observe network path changes from a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/NetworkReachability\/documentation\/NetworkReachability\/NetworkMonitor"}],"identifier":"doc:\/\/NetworkReachability\/documentation\/NetworkReachability\/NetworkMonitorDelegate","kind":"symbol","type":"topic","navigatorTitle":[{"kind":"identifier","text":"NetworkMonitorDelegate"}],"url":"\/documentation\/networkreachability\/networkmonitordelegate"}}}